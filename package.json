{
	"name": "@kucrut/svelte-location-picker",
	"description": "Simple location picker for Svelte projects.",
	"version": "0.0.8",
	"homepage": "https://kucrut.gitlab.io/svelte-location-picker",
	"license": "MIT",
	"packageManager": "pnpm@7.5.2",
	"type": "module",
	"bugs": {
		"url": "https://gitlab.com/kucrut/svelte-location-picker/-/issues"
	},
	"contributors": [
		{
			"name": "Dzikri Aziz",
			"url": "https://dz.aziz.im"
		}
	],
	"engines": {
		"pnpm": "^7.0.0"
	},
	"keywords": [
		"form",
		"geolocation",
		"leaflet",
		"map",
		"svelte"
	],
	"repository": {
		"type": "git",
		"url": "https://gitlab.com/kucrut/svelte-location-picker"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"package": "svelte-kit sync && svelte-package",
		"preview": "vite preview",
		"test": "playwright test",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check --plugin-search-dir=. . && eslint .",
		"format": "prettier --write --plugin-search-dir=. ."
	},
	"devDependencies": {
		"@changesets/cli": "^2.25.2",
		"@kucrut/svelte-stuff": "^0.0.2",
		"@playwright/test": "^1.28.1",
		"@sveltejs/adapter-static": "1.0.0-next.48",
		"@sveltejs/kit": "1.0.0-next.571",
		"@sveltejs/package": "1.0.0-next.6",
		"@types/geojson": "^7946.0.10",
		"@types/leaflet": "^1.9.0",
		"@typescript-eslint/eslint-plugin": "^5.45.0",
		"@typescript-eslint/parser": "^5.45.0",
		"eslint": "^8.29.0",
		"eslint-config-prettier": "^8.3.0",
		"eslint-plugin-prettier": "^4.2.1",
		"eslint-plugin-svelte3": "^4.0.0",
		"leaflet": "^1.9.3",
		"prettier": "^2.8.0",
		"prettier-plugin-svelte": "^2.8.1",
		"svelte": "^3.53.1",
		"svelte-check": "^2.10.0",
		"svelte-preprocess": "^4.10.7",
		"svelte2tsx": "^0.5.21",
		"tslib": "^2.4.1",
		"typescript": "~4.9.3",
		"vite": "^3.2.4"
	},
	"peerDependencies": {
		"@kucrut/svelte-stuff": "^0.0.1",
		"leaflet": "^1.9.3",
		"svelte": "^3.53.1"
	}
}
