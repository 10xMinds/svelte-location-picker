{
	"name": "@kucrut/svelte-location-picker",
	"description": "Simple location picker for Svelte projects.",
	"version": "0.2.0",
	"homepage": "https://kucrut.gitlab.io/svelte-location-picker",
	"license": "MIT",
	"packageManager": "pnpm@8.8.0",
	"type": "module",
	"bugs": {
		"url": "https://gitlab.com/kucrut/svelte-location-picker/-/issues"
	},
	"contributors": [
		{
			"name": "Dzikri Aziz",
			"url": "https://dz.aziz.im"
		}
	],
	"engines": {
		"pnpm": "^8.8.0"
	},
	"keywords": [
