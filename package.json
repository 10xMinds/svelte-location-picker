{
	"name": "@10xminds/svelte-location-picker",
	"description": "Simple location picker for Svelte projects.",
	"version": "0.2.3",
	"homepage": "https://github.com/10xminds/svelte-location-picker",
	"license": "MIT",
	"packageManager": "pnpm@9.12.1",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"bugs": {
		"url": "https://github.com/10xminds/svelte-location-picker/-/issues"
	},
	"contributors": [
		{
			"name": "Dzikri Aziz",
			"url": "https://dz.aziz.im"
		},
		{
			"name": "Vish",
			"email": "vishnu@10xminds.dev"
		}
	],
	"engines": {
		"pnpm": "^9.12.1"
	},
	"keywords": [
		"form",
		"geolocation",
		"leaflet",
		"map",
		"svelte"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/10xminds/svelte-location-picker"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"package": "svelte-kit sync && svelte-package",
		"preview": "vite preview",
